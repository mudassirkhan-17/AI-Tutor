# ---- Supabase ----
# For instant email/password signup (no inbox step): Dashboard → Authentication →
# Providers → Email → disable "Confirm email".
# Auth is rate-limited per IP on Supabase (signups / magic links / emails). If you
# hammer "Create account" while testing, wait ~60s or use Google once.
#
# One-click demo login (used by /api/auth/demo):
#   - Requires SUPABASE_SERVICE_ROLE_KEY above.
#   - Override defaults if you want:
# DEMO_EMAIL=demo@tutor.local
# DEMO_PASSWORD=demo-tutor-1234
#   - Disable in production:
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-only, never expose

# ---- AI (at least one required for chat) ----
AI_PROVIDER=anthropic                              # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_MODEL=gpt-4o-mini

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
